NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/kini_outsourcing
CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TRUST_PROXY=false

# Cloudflare Turnstile test secret. Replace it before production.
TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA

# Local-only Postman/browser testing helpers. Never enable CAPTCHA bypass in production.
ENABLE_DEV_CAPTCHA_BYPASS=false
DISABLE_DEV_SMTP=false

# Generate a secure admin password and hash with:
# npm run admin:generate
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=replace-with-another-long-random-secret
ADMIN_RESET_URL=http://localhost:5173/admin
ENABLE_DEV_ADMIN_RESET=false

# SMTP is used for lead notifications and admin password reset emails.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=KINi Outsourcing Services <no-reply@example.com>
CONSULTANT_EMAIL=kinioutsourcingservices@gmail.com
