NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/kini_outsourcing
CLIENT_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
TRUST_PROXY=false

TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
OTP_PEPPER=replace-with-a-long-random-secret
ENABLE_DEV_OTP=true

ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD_HASH=
ADMIN_SESSION_SECRET=replace-with-another-long-random-secret
ADMIN_RESET_URL=http://localhost:5173/admin
ENABLE_DEV_ADMIN_RESET=true

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=KINi Outsourcing Services <no-reply@example.com>
CONSULTANT_EMAIL=kinioutsourcingservices@gmail.com
